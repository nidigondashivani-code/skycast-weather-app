# OpenWeatherMap API Key (Get yours at https://openweathermap.org/)
OPENWEATHER_API_KEY=your_api_key_here

# Default Cities to Monitor (comma separated)
CITIES=Hyderabad,Mumbai,Delhi,Bangalore,Chennai

# Email Configuration (for alerts)
# Use an App Password if using Gmail
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password

# Alert Recipients (comma separated)
ALERT_RECIPIENTS=recipient1@gmail.com,recipient2@gmail.com
